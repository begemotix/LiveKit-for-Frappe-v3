# Entwickler-ENV fuer apps/agent. Kundenfacing-Dokumentation liegt in
# ../../.env.example und readme/MISTRAL-AGENT.md.

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ========================================
# TYPE_A: OpenAI Realtime (US path)
# ========================================
OPENAI_API_KEY=

# ========================================
# TYPE_B: MistralOrchestrator + LiveKit NullLLM
# ========================================
# Welcher Voice-Stack soll laufen (type_a = OpenAI US, type_b = Mistral EU).
# Leer lassen = Default type_b.
AGENT_MODE=type_b

# Mistral API Key (la plateforme).
MISTRAL_API_KEY=

# Persistent Agent aus https://console.mistral.ai (Format: ag_...).
# Hoste hier die Persoenlichkeit + Modellwahl; an dieser Stelle werden
# KEINE Functions/Connectors gepflegt — die MCP-Tools werden zur Laufzeit
# via MCPClientSTDIO an den Mistral RunContext angehaengt.
MISTRAL_AGENT_ID=ag_019db5cd1ea0733e875cc4d6311c403f

# Dev-only: wenn true, ueberspringt der Agent den Console-Pfad und
# nutzt chat.complete direkt mit MISTRAL_LLM_MODEL. In Produktion false.
MISTRAL_STATELESS_MODE=false
MISTRAL_LLM_MODEL=mistral-medium-latest

# Voxtral STT/TTS-Modelle.
# STT: Der livekit-mistralai-Plugin erkennt "realtime" im Namen und
# oeffnet dann einen WebSocket-Streaming-Pfad (niedrige Latenz, Flush
# per VAD). Fallback-Batch: voxtral-mini-latest.
VOXTRAL_STT_MODEL=voxtral-mini-transcribe-realtime-2602
# TTS: voxtral-mini-tts-latest (rollierend) oder voxtral-mini-tts-2603.
# model_factory wrappt die Synthese in StreamAdapter+SentenceStreamPacer,
# damit lange Antworten in gebatchten Saetzen synthetisiert werden und
# die Audio-Ausgabe nicht zwischen Satzgrenzen stottert.
VOXTRAL_TTS_MODEL=voxtral-mini-tts-latest

# Sprache fuer STT: nur "de" oder "en".
AGENT_LANGUAGE=de

# Voice-Auswahl fuer type_b (genau eines von beiden).
AGENT_VOICE_ID=de-DE-EliseNeural
AGENT_VOICE_REF_AUDIO=

# Branding & Identity
AGENT_NAME=Assistant
COMPANY_NAME=Frappe
ROLE_DESCRIPTION=You are {AGENT_NAME}, a helpful assistant for {COMPANY_NAME}.
INITIAL_GREETING=Hello, I am {AGENT_NAME}. How can I help you today?
MANDATORY_ANNOUNCEMENT=Hinweis: Sie sprechen mit einem KI-Assistenten. Audio-Daten werden zur Verarbeitung an OpenAI in den USA übertragen. Durch Fortsetzen des Gesprächs willigen Sie ein.

# Agent Configuration
AGENT_VOICE=alloy
VAD_THRESHOLD=0.5
VAD_SILENCE_DURATION_MS=500
# Phase 4: Frappe MCP via local stdio sidecar (same as Cursor: npx frappe-mcp-server).
FRAPPE_URL=https://<your-frappe-host>
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
