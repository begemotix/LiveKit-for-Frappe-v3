# Environment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Internally used environment variables
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=http://localhost:3000/api/connection-details
# NEXT_PUBLIC_APP_CONFIG_ENDPOINT=

# Branding Configuration
# NEXT_PUBLIC_WIDGET_PRIMARY_COLOR=#002cf2
# NEXT_PUBLIC_WIDGET_PRIMARY_HOVER_COLOR=#0020b9
# NEXT_PUBLIC_WIDGET_PRIMARY_COLOR_DARK=#1fd5f9
# NEXT_PUBLIC_WIDGET_PRIMARY_HOVER_COLOR_DARK=#19a7c7
