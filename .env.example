# --- LiveKit Server Credentials ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
DOMAIN=live.example.com

# --- Python Agent (apps/agent) ---
LIVEKIT_URL=wss://live.example.com
OPENAI_API_KEY=sk-...

# Frappe MCP (stdio Sidecar — gleicher Vertrag wie Cursor)
FRAPPE_URL=https://ihre-frappe-instanz.example
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# Agent Persona & White-Labeling
AGENT_NAME=Assistant
COMPANY_NAME=My Company
INITIAL_GREETING=Hello, I am {AGENT_NAME}. How can I help you?
MANDATORY_ANNOUNCEMENT=Notice: You are speaking with an AI assistant...

# ========================================
# TYPE_B: MistralOrchestrator + LiveKit NullLLM
# ========================================
# EU voice path (Mistral + Voxtral). Vollstaendige Anleitung in
# readme/MISTRAL-AGENT.md. Persoenlichkeit und System-Prompt liegen im
# Mistral-Console-Agenten; LiveKit uebernimmt nur STT/VAD/TTS. MCP-Tools
# werden zur Laufzeit per mistralai.extra.mcp.stdio.MCPClientSTDIO an
# den Mistral RunContext gebunden — kein LiveKit MCPToolset in type_b.

# Welcher Voice-Stack soll laufen: type_b = Mistral+Voxtral (EU),
# type_a = OpenAI Realtime (US). Leer lassen = type_b.
AGENT_MODE=type_b

# Mistral API Key (la plateforme). In Coolify als "Secret/Hidden"
# speichern.
MISTRAL_API_KEY=sk-proj-...

# Persistent Agent aus https://console.mistral.ai. Traegt System-Prompt,
# Modell, Temperatur. Einrichtung: readme/MISTRAL-AGENT.md Teil 2.
MISTRAL_AGENT_ID=ag_019db5cd1ea0733e875cc4d6311c403f

# --- Voxtral (STT/TTS fuer type_b) ---
# Platzhalter-Werte — durch euren konkreten Voxtral-Modellnamen ersetzen
# (Beispiele: voxtral-mini-latest fuer STT, voxtral-mini-tts fuer TTS).
VOXTRAL_STT_MODEL=voxtral-tts-v1
VOXTRAL_TTS_MODEL=voxtral-tts-v1

# --- Voice fuer type_b (genau eines der beiden setzen) ---
# Standardstimme aus dem Voxtral-Katalog.
AGENT_VOICE_ID=de-DE-EliseNeural
# ODER referenziertes Audio-File fuer Voice-Cloning (wenn gesetzt,
# ueberschreibt es AGENT_VOICE_ID). Pfad muss im Container lesbar sein.
# AGENT_VOICE_REF_AUDIO=/app/voice_refs/de_anja.mp3

# Sprache fuer STT (nur "de" oder "en").
AGENT_LANGUAGE=de

# --- Dev-only Escape Hatches (in Produktion auf Default lassen) ---
# Wenn true, umgeht der Agent den Console-Pfad und ruft chat.complete
# direkt mit MISTRAL_LLM_MODEL als Modell. In Produktion MUSS false
# bleiben — sonst laeuft eure Persoenlichkeit nicht.
MISTRAL_STATELESS_MODE=false
# Wird nur gelesen wenn MISTRAL_STATELESS_MODE=true.
MISTRAL_LLM_MODEL=mistral-medium-latest

# --- Frontend (apps/frontend) ---
NEXT_PUBLIC_LIVEKIT_URL=wss://live.example.com
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=/api/connection-details
